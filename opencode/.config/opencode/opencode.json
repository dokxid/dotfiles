{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "model": "github-copilot/claude-haiku-4.5",
  "agent": {
    "plan": {
      "temperature": 0.3,
    },
    "build": {
      "temperature": 0.1,
      "disable": true,
    },
    "edit": {
      "description": "Full development agent with all tools enabled",
      "mode": "primary",
      "prompt": "You are a software engineering agent. You have full access to all tools and can read, write, edit files, and run commands. Help the user with any development task.",
      "temperature": 0.2,
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "glob": true,
        "grep": true,
        "read": true,
        "webfetch": true,
      },
    }
  },
  "permission": {
    "*": "ask",
    "read": {
      "~/.config/opencode/rules/*": "allow",
      "/tmp/*": "allow",
      "*": "allow",
      "*.env.local": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "task": "allow",
    "lsp": "allow",
    "find": "allow",
    "skill": "allow",
    "glob": "allow",
    "list": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "edit": "ask",
    "bash": "ask",
    "todowrite": "allow",
  },
  "mcp": {
    "postgres": {
      "enabled": false,
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "DATABASE_URI",
        "crystaldba/postgres-mcp",
        "--access-mode=unrestricted"
      ],
      "environment": {
        "DATABASE_URI": "{file:~/.secrets/postgres_database_uri}"
      }
    },
    "nuxt": {
      "type": "remote",
      "url": "https://nuxt.com/mcp",
      "enabled": true
    },
    "nuxt-ui": {
      "type": "remote",
      "url": "https://ui.nuxt.com/mcp",
      "enabled": true
    }
  }
}
