{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "plan": {
      "temperature": 0.3,
      "model": "github-copilot/claude-opus-4.6"
    },
    "build": {
      "temperature": 0.1,
      "disable": true,
      "model": "github-copilot/claude-opus-4.6"
    },
    "edit": {
      "description": "Full development agent with all tools enabled",
      "mode": "primary",
      "prompt": "You are a software engineering agent. You have full access to all tools and can read, write, edit files, and run commands. Help the user with any development task.",
      "temperature": 0.2,
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "glob": true,
        "grep": true,
        "read": true,
        "webfetch": true,
        "todowrite": true
      },
    }
  },
  "permission": {
    "*": "ask",
    "read": {
      "~/.config/**": "allow",
      "~/dotfiles/**": "allow"
    },
    "webfetch": "allow",
    "edit": "ask",
    "bash": "ask",
  },
  "mcp": {
    "postgres": {
      "enabled": false,
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "DATABASE_URI",
        "crystaldba/postgres-mcp",
        "--access-mode=unrestricted"
      ],
      "environment": {
        "DATABASE_URI": "{file:~/.secrets/postgres_database_uri}"
      }
    }
  }
}
